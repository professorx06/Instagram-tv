<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:type="linear"
                android:angle="45"
                android:startColor="#f09433"
                android:centerColor="#dc2743"
                android:endColor="#bc1888" />
            <corners android:radius="20dp" />
        </shape>
    </item>
    <item
        android:top="15dp"
        android:bottom="15dp"
        android:left="15dp"
        android:right="15dp">
        <shape android:shape="rectangle">
            <stroke
                android:width="3dp"
                android:color="#FFFFFF" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item
        android:top="28dp"
        android:bottom="28dp"
        android:left="28dp"
        android:right="28dp">
        <shape android:shape="oval">
            <stroke
                android:width="3dp"
                android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:top="20dp"
        android:bottom="62dp"
        android:left="62dp"
        android:right="20dp">
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
</layer-list>
